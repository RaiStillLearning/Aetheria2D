# Asset meta data should be included
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta

# Ignore Visual Studio / Rider
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
.idea/

# Unity cache server
[Cc]ache/

# OS files
.DS_Store
Thumbs.db

# Builds
*.apk
*.aab
*.unitypackage

# Addressables
ServerData/

# Crash reports
sysinfo.txt